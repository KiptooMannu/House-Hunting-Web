# Environment
NODE_ENV=development
PORT=5000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=house_hunting_db
DB_USER=your_pg_user
DB_PASSWORD=your_pg_password

# JWT
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# M-Pesa Daraja API
# Register at https://developer.safaricom.co.ke to get credentials
# Use MPESA_ENV=sandbox for testing, MPESA_ENV=production for live
# For local dev, use ngrok to expose your callback URL
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_PASSKEY=your_daraja_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/payments/mpesa/callback

# GavaConnect (KRA) API
# Register at https://developer.go.ke to get credentials
# Use GAVA_ENV=sandbox for testing, GAVA_ENV=production for live
GAVA_ENV=sandbox
GAVA_CONSUMER_KEY=your_gava_consumer_key
GAVA_CONSUMER_SECRET=your_gava_consumer_secret
GAVA_API_URL=https://sandbox.developer.go.ke
